<%- messages() %>

<main class="home">

  <!-- HERO SECTION -->
  <section class="hero">
    <img 
      data-src="/images/vehicles/delorean.jpg"
      alt="DMC Delorean Hero Image"
      class="hero-img"
    >

    <div class="hero-text">
      <h1>Own Today</h1>
      <p>Find the perfect vehicle for your next adventure.</p>
    </div>
  </section>

  <!-- DMC DELOREAN REVIEWS -->
  <section class="reviews">
    <h2>DMC Delorean Reviews</h2>
    <ul>
      <li>"The flux capacitor really makes this car fly!"</li>
      <li>"Great Scott! What a ride."</li>
      <li>"Handles like a dream through time and space."</li>
      <li>"A true classic with futuristic charm."</li>
      <li>"Perfect for weekend trips… to 1955."</li>
    </ul>
  </section>

  <!-- DELOREAN UPGRADES -->
  <section class="upgrades">
    <h2>Delorean Upgrades</h2>

    <div class="upgrade-grid">

      <div class="upgrade-card">
        <img data-src="/images/upgrades/flux-cap.png" alt="Flux Capacitor">
        <p>Flux Capacitor</p>
      </div>

      <div class="upgrade-card">
        <img data-src="/images/upgrades/flame.jpg" alt="Flame Decals">
        <p>Flame Decals</p>
      </div>

      <div class="upgrade-card">
        <img data-src="/images/upgrades/hub-cap.jpg" alt="Hub Caps">
        <p>Hub Caps</p>
      </div>

      <div class="upgrade-card">
        <img data-src="/images/upgrades/bumper_sticker.jpg" alt="Bumper Sticker">
        <p>Bumper Sticker</p>
      </div>

    </div>
  </section>

</main>

<script src="/js/script.js"></script>