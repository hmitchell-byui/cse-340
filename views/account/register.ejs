<h1><%= title %></h1>

<!-- Flash Message -->
<% if (locals.message) { %>
  <div class="notice"><%= message %></div>
<% } %>

<form action="/account/register" method="post" class="account-form">

  <!-- First Name -->
  <label for="account_firstname">First Name:</label>
  <input 
    type="text" 
    id="account_firstname" 
    name="account_firstname" 
    required
    value="<%= typeof account_firstname !== 'undefined' ? account_firstname : '' %>"
  >

  <!-- Last Name -->
  <label for="account_lastname">Last Name:</label>
  <input 
    type="text" 
    id="account_lastname" 
    name="account_lastname" 
    required
    value="<%= typeof account_lastname !== 'undefined' ? account_lastname : '' %>"
  >

  <!-- Email -->
  <label for="account_email">Email:</label>
  <input 
    type="email" 
    id="account_email" 
    name="account_email" 
    required
    value="<%= typeof account_email !== 'undefined' ? account_email : '' %>"
  >

  <!-- Password -->
  <label for="account_password">Password:</label>
  <input 
    type="password" 
    id="account_password" 
    name="account_password" 
    required
    minlength="12"
    title="Must be at least 12 characters, include 1 capital letter, 1 number, and 1 special character."
  >

  <!-- Optional Password Toggle -->
  <button type="button" id="togglePassword" class="toggle-btn">
    Show Password
  </button>

  <button type="submit">Register</button>
</form>

<p class="account-link">
  Already have an account?
  <a href="/account/login">Login</a>
</p>

<script>
  // Optional password toggle
  const toggleBtn = document.getElementById("togglePassword")
  const pwd = document.getElementById("account_password")

  toggleBtn.addEventListener("click", () => {
    const type = pwd.getAttribute("type") === "password" ? "text" : "password"
    pwd.setAttribute("type", type)
    toggleBtn.textContent = type === "password" ? "Show Password" : "Hide Password"
  })
</script>
